{
  "$schema": "vscode://schemas/color-theme",
  "type": "dark",
  "name": "Carl Azuz Theme",
  "colors": {
    "editor.background": "#00000000",
    "sideBar.background": "#00000000",
    "activityBar.background": "#00000000",
    "titleBar.activeBackground": "#00000000",
    "titleBar.inactiveBackground": "#00000000",
    "editor.foreground": "#FFFFFF",
    "sideBar.foreground": "#FFFFFF"
  },
  "tokenColors": [
    {
      "scope": ["keyword"],
      "settings": { "foreground": "#4FC3F7" }
    },
    {
      "scope": ["string"],
      "settings": { "foreground": "#FFEB3B" }
    },
    {
      "scope": ["variable"],
      "settings": { "foreground": "#81D4FA" }
    },
    {
      "scope": ["comment"],
      "settings": { "foreground": "#9E9E9E", "fontStyle": "italic" }
    }
  ]
}
